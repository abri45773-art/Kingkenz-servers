      <div class="stat-bar"><div class="stat-label">SPEED</div><div class="stat-meter"><div class="stat-fill" style="width:${c.stats.speed}%"></div></div></div>
      <div class="stat-bar"><div class="stat-label">DEFENSE</div><div class="stat-meter"><div class="stat-fill" style="width:${c.stats.defense}%"></div></div></div>
      <div class="stat-bar"><div class="stat-label">SPECIAL</div><div class="stat-meter"><div class="stat-fill" style="width:${c.stats.special}%"></div></div></div>
      <div class="char-desc">${c.desc}</div>
    `;
    card.addEventListener('click', () => selectCharacter(c));
    grid.appendChild(card);

    // Draw preview character
    setTimeout(() => drawPreview(i, c), 50);
  });
}

function drawPreview(i, charData) {
  const cv = document.getElementById(`preview_${i}`);
  if (!cv) return;
  const cx = cv.getContext('2d');
  cx.clearRect(0,0,cv.width,cv.height);

  // Glow
  const glow = cx.createRadialGradient(60, 140, 0, 60, 140, 80);
  glow.addColorStop(0, charData.color + '40');
  glow.addColorStop(1, 'transparent');
  cx.fillStyle = glow;
  cx.fillRect(0,0,cv.width,cv.height);

  cx.save();
  cx.translate(60, 170);
  // Simple standing figure
  cx.fillStyle = 'rgba(0,0,0,0.5)';
  cx.beginPath(); cx.ellipse(0, 0, 25, 5, 0, 0, Math.PI*2); cx.fill();

  // Legs
  cx.fillStyle = charData.color2;
  cx.fillRect(-12, -50, 10, 50);
  cx.fillRect(2, -50, 10, 50);

  // Body
  cx.fillStyle = charData.color;
  cx.fillRect(-18, -95, 36, 50);

  // Belt
  cx.fillStyle = charData.accent;
  cx.fillRect(-18, -60, 36, 5);

  // Arms
  cx.fillStyle = charData.color;
  cx.fillRect(-24, -92, 8, 38);
  cx.fillRect(16, -92, 8, 38);

  // Head
  cx.fillStyle = '#f4c2a1';
  cx.beginPath(); cx.arc(0, -108, 15, 0, Math.PI*2); cx.fill();

  // Hair
  cx.fillStyle = charData.color;
  if (charData.id === 'ryuki') {
    cx.beginPath();
    cx.moveTo(-15,-108); cx.lineTo(-18,-130); cx.lineTo(-8,-120);
    cx.lineTo(-3,-135); cx.lineTo(3,-120); cx.lineTo(8,-130); cx.lineTo(15,-108);
    cx.closePath(); cx.fill();
  } else if (charData.id === 'blaze') {
    cx.fillStyle = '#ffaa00';
    cx.beginPath();
    cx.moveTo(-15,-108); cx.lineTo(-12,-135); cx.lineTo(-3,-125);
    cx.lineTo(0,-140); cx.lineTo(3,-125); cx.lineTo(12,-135); cx.lineTo(15,-108);
    cx.closePath(); cx.fill();
  } else if (charData.id === 'kaze') {
    cx.fillStyle = charData.color2;
    cx.fillRect(-15, -108, 30, 10);
  }

  // Eyes
  if (charData.id !== 'kaze') {
    cx.fillStyle = '#fff';
    cx.fillRect(-6,-110,3,3); cx.fillRect(3,-110,3,3);
  }

  cx.restore();
}

function selectCharacter(charData) {
  SFX.select();
  if (game.selectingPlayer === 1) {
    game.p1Char = charData;
    if (game.mode === 'cpu') {
      // CPU picks random different character
      const options = CHARACTERS.filter(c => c.id !== charData.id);
      game.p2Char = options[Math.floor(Math.random() * options.length)];
      startFight();
    } else {
      game.selectingPlayer = 2;
      updateSelectPrompt();
      buildCharGrid();
    }
  } else {
    game.p2Char = charData;
    startFight();
  }
}

function startFight() {
  document.getElementById('charSelect').style.display = 'none';
  document.getElementById('gameHUD').style.display = 'flex';
  game.state = 'fighting';
  game.round = 1;
  game.p1Wins = 0;
  game.p2Wins = 0;

  document.getElementById('p1Name').textContent = game.p1Char.name;
  document.getElementById('p2Name').textContent = game.p2Char.name;

  startRound();
}

function startRound() {
  fighters = [
    new Fighter(game.p1Char, canvas.width * 0.3, true, false),
    new Fighter(game.p2Char, canvas.width * 0.7, false, game.mode === 'cpu')
  ];

  document.getElementById('roundText').textContent = `ROUND ${game.round}`;
  showCenterMessage('ROUND ' + game.round, 1500);
  SFX.round();
  setTimeout(() => {
    showCenterMessage('FIGHT!', 1000);
    game.timer = 60;
    if (game.timerInterval) clearInterval(game.timerInterval);
    game.timerInterval = setInterval(() => {
      if (game.state === 'fighting') {
        game.timer--;
        document.getElementById('timer').textContent = Math.max(0, game.timer);
        if (game.timer <= 0) {
          endRound();
        }
      }
    }, 1000);
    game.state = 'fighting';
  }, 1800);
}

function endRound() {
  if (game.state !== 'fighting') return;
  game.state = 'roundEnd';
  clearInterval(game.timerInterval);

  const p1 = fighters[0], p2 = fighters[1];
  let winner;
  if (p1.health <= 0) { winner = 'p2'; game.p2Wins++; }
  else if (p2.health <= 0) { winner = 'p1'; game.p1Wins++; }
  else if (p1.health > p2.health) { winner = 'p1'; game.p1Wins++; }
  else if (p2.health > p1.health) { winner = 'p2'; game.p2Wins++; }
  else { /* draw, no wins */ }

  if (winner === 'p1') showCenterMessage('P1 WINS!', 2000);
  else if (winner === 'p2') showCenterMessage('P2 WINS!', 2000);
  else showCenterMessage('DRAW!', 2000);

  setTimeout(() => {
    if (game.p1Wins >= 2 || game.p2Wins >= 2) {
      showVictory();
    } else {
      game.round++;
      fighters[0].reset(canvas.width * 0.3);
      fighters[1].reset(canvas.width * 0.7);
      startRound();
    }
  }, 2500);
}

function showVictory() {
  game.state = 'victory';
  const screen = document.getElementById('victoryScreen');
  const title = document.getElementById('victoryTitle');
  const text = document.getElementById('victoryText');

  if (game.p1Wins > game.p2Wins) {
    title.textContent = 'VICTORY';
    text.textContent = `${game.p1Char.name} WINS!`;
    text.style.color = game.p1Char.color;
  } else {
    title.textContent = game.mode === 'cpu' ? 'DEFEAT' : 'VICTORY';
    text.textContent = `${game.p2Char.name} WINS!`;
    text.style.color = game.p2Char.color;
  }
  screen.style.display = 'flex';
}

function restartGame() {
  document.getElementById('victoryScreen').style.display = 'none';
  document.getElementById('gameHUD').style.display = 'none';
  game.state = 'select';
  game.selectingPlayer = 1;
  document.getElementById('charSelect').style.display = 'flex';
  buildCharGrid();
  updateSelectPrompt();
}

function backToTitle() {
  document.getElementById('victoryScreen').style.display = 'none';
  document.getElementById('charSelect').style.display = 'none';
  document.getElementById('gameHUD').style.display = 'none';
  document.getElementById('titleScreen').style.display = 'flex';
  game.state = 'title';
}

function showCenterMessage(msg, duration) {
  const el = document.getElementById('centerMsg');
  el.textContent = msg;
  el.classList.add('show');
  if (game.centerMsgTimeout) clearTimeout(game.centerMsgTimeout);
  game.centerMsgTimeout = setTimeout(() => {
    el.classList.remove('show');
  }, duration);
}

// ============ MAIN LOOP ============
let lastTime = performance.now();
function gameLoop(now) {
  let dt = (now - lastTime) / 1000;
  lastTime = now;
  if (dt > 0.1) dt = 0.1;

  // Slowmo effect
  if (game.slowmo > 0) {
    dt *= 0.3;
    game.slowmo -= 0.016;
  }

  // Update
  handleInput();
  if (fighters.length === 2 && (game.state === 'fighting' || game.state === 'roundEnd')) {
    fighters[0].update(dt, fighters[1]);
    fighters[1].update(dt, fighters[0]);

    // Check KO
    if (game.state === 'fighting') {
      if (fighters[0].health <= 0 || fighters[1].health <= 0) {
        setTimeout(() => endRound(), 1500);
        game.state = 'roundEnd';
        showCenterMessage('K.O.!', 1500);
      }
    }
  }
  updateParticles(dt);

  // Shake
  if (game.shakeAmount > 0) game.shakeAmount *= 0.9;

  // Draw
  ctx.save();
  if (game.shakeAmount > 0.5) {
    ctx.translate(
      (Math.random()-0.5) * game.shakeAmount,
      (Math.random()-0.5) * game.shakeAmount
    );
  }

  drawBackground(ctx);

  if (fighters.length === 2) {
    // Draw in order (back to front)
    const sorted = [...fighters].sort((a,b) => a.y - b.y);
    sorted.forEach(f => f.draw(ctx));
  }

  drawParticles(ctx);
  drawComboTexts(ctx);

  ctx.restore();

  // Update HUD
  if (fighters.length === 2) {
    document.getElementById('p1Health').style.width = fighters[0].health + '%';
    document.getElementById('p2Health').style.width = fighters[1].health + '%';
    document.getElementById('p1Special').style.width = fighters[0].special + '%';
    document.getElementById('p2Special').style.width = fighters[1].special + '%';
  }

  requestAnimationFrame(gameLoop);
}

requestAnimationFrame(gameLoop);
</script>
